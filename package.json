{
  "name": "ohmyqwen",
  "version": "0.1.0-alpha",
  "description": "Local agentic coding runtime skeleton for Qwen3 in closed network",
  "type": "module",
  "bin": {
    "ohmyqwen": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run build:qmd:vendor",
    "build:qmd:vendor": "pnpm exec tsc -p vendor/qmd/tsconfig.build.json",
    "lint": "pnpm run typecheck",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "bundle:offline": "bash ./scripts/bundle-offline.sh",
    "bundle:offline:win64": "pwsh -File ./scripts/bundle-offline-win64.ps1",
    "qmd:health": "pnpm build && node ./scripts/verify-offline-win64.mjs --require-models false",
    "verify:offline:win64": "pnpm build && node ./scripts/verify-offline-win64.mjs",
    "eval:retrieval": "node ./scripts/eval-retrieval.mjs --tasks ./samples/retrieval-eval.tasks.json",
    "run": "node dist/cli.js run",
    "plan": "node dist/cli.js plan",
    "verify": "node dist/cli.js verify",
    "serve": "node dist/cli.js serve",
    "ui:dev": "pnpm --dir console-next dev",
    "ui:build": "pnpm --dir console-next build",
    "ui:start": "pnpm --dir console-next start"
  },
  "keywords": [
    "agent",
    "runtime",
    "qwen3",
    "state-machine"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "better-sqlite3": "^11.0.0",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.0",
    "node-llama-cpp": "^3.14.5",
    "picomatch": "^4.0.0",
    "sqlite-vec": "^0.1.7-alpha.2",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "node-llama-cpp"
    ]
  }
}
