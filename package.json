{
  "name": "ohmyqwen",
  "version": "0.1.0-alpha",
  "description": "Local agentic coding runtime skeleton for Qwen3 in closed network",
  "type": "module",
  "bin": {
    "ohmyqwen": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "pnpm run typecheck",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "bundle:offline": "bash ./scripts/bundle-offline.sh",
    "run": "node dist/cli.js run",
    "plan": "node dist/cli.js plan",
    "verify": "node dist/cli.js verify",
    "serve": "node dist/cli.js serve",
    "ui:dev": "pnpm --dir console-next dev",
    "ui:build": "pnpm --dir console-next build",
    "ui:start": "pnpm --dir console-next start"
  },
  "keywords": [
    "agent",
    "runtime",
    "qwen3",
    "state-machine"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
