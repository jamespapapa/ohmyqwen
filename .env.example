# LLM (OpenAI-compatible)
OHMYQWEN_LLM_BASE_URL=http://127.0.0.1:8000
OHMYQWEN_LLM_MODEL=qwen3-coder
# auto(openai 먼저 시도 후 필요시 opencode session API fallback) | openai | opencode
OHMYQWEN_LLM_ENDPOINT_KIND=auto
# Optional (Bearer)
OHMYQWEN_LLM_API_KEY=

# Optional (Basic auth)
# Accepted formats:
# - OHMYQWEN_LLM_BASIC_AUTH=user:password
# - OHMYQWEN_LLM_BASIC_AUTH=user/password
OHMYQWEN_LLM_BASIC_AUTH=
# Optional split form
OHMYQWEN_LLM_BASIC_AUTH_USER=
OHMYQWEN_LLM_BASIC_AUTH_PASSWORD=

# Optional dependency allowlist fallback URL
OHMYQWEN_AVAILABLE_LIBRARIES_URL=

# Optional retrieval/embedding (offline local service)
OHMYQWEN_RETRIEVAL_PROVIDERS=qmd,hybrid,lexical,semantic
OHMYQWEN_RETRIEVAL_STAGE_CAP_PLAN=1200
OHMYQWEN_RETRIEVAL_STAGE_CAP_IMPLEMENT=1800
OHMYQWEN_RETRIEVAL_STAGE_CAP_VERIFY=1000
OHMYQWEN_CONTEXT_CHUNK_VERSION=v1
OHMYQWEN_RETRIEVAL_VERSION=v2-qmd-hybrid
OHMYQWEN_REINDEX_ON_STALE=1
OHMYQWEN_EMBEDDING_ENABLED=0
OHMYQWEN_EMBEDDING_ENDPOINT=http://127.0.0.1:8081
OHMYQWEN_EMBEDDING_HEALTH_PATH=/health
OHMYQWEN_EMBEDDING_EMBED_PATH=/embed
OHMYQWEN_EMBEDDING_MODEL=local-embedding
OHMYQWEN_EMBEDDING_TIMEOUT_MS=2000

# Optional plugin: gitlab-logs
OHMYQWEN_GITLAB_BASE_URL=https://gitlab.example.com
OHMYQWEN_GITLAB_PROJECT_ID=123
OHMYQWEN_GITLAB_TOKEN=
