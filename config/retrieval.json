{
  "providerPriority": ["qmd", "hybrid", "lexical", "semantic"],
  "topK": {
    "qmd": 24,
    "lexical": 32,
    "semantic": 24,
    "hybrid": 32,
    "final": 40
  },
  "timeoutMs": {
    "qmd": 5000,
    "semantic": 2500,
    "provider": 3000
  },
  "stageTokenCaps": {
    "PLAN": 1200,
    "IMPLEMENT": 1800,
    "VERIFY": 1000
  },
  "embedding": {
    "enabled": false,
    "healthPath": "/health",
    "embedPath": "/embed",
    "model": "local-embedding",
    "timeoutMs": 2000,
    "maxBatchSize": 64,
    "cachePath": ".ohmyqwen/cache/embedding-cache.json"
  },
  "lifecycle": {
    "chunkVersion": "v1",
    "retrievalVersion": "v3-qmd-cli",
    "autoReindexOnStale": true
  },
  "qmd": {
    "enabled": true,
    "command": "qmd",
    "collectionName": "workspace",
    "mask": "**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,java,kt,kts,xml,yml,yaml,py,go,rs,sql,sh}",
    "queryMode": "query_then_search",
    "syncIntervalMs": 60000
  }
}
