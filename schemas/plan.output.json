{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlanOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "steps"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "retryPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxAttempts", "backoffMs"],
      "properties": {
        "maxAttempts": { "type": "integer", "minimum": 1 },
        "backoffMs": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
