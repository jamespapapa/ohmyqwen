{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnalyzeInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["taskId", "objective"],
  "properties": {
    "taskId": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "availableLibraries": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "maxItems": 200
    },
    "availableLibrariesFile": {
      "type": "string",
      "minLength": 1
    },
    "availableLibrariesUrl": {
      "type": "string",
      "format": "uri"
    },
    "files": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "symbols": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "errorLogs": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "diffSummary": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "contextTier": {
      "type": "string",
      "enum": ["small", "mid", "big"],
      "default": "small"
    },
    "contextTokenBudget": {
      "type": "integer",
      "minimum": 200,
      "maximum": 12000,
      "default": 1200
    },
    "retryPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxAttempts", "backoffMs", "sameFailureLimit", "rollbackOnVerifyFail"],
      "properties": {
        "maxAttempts": { "type": "integer", "minimum": 1 },
        "backoffMs": { "type": "integer", "minimum": 0 },
        "sameFailureLimit": { "type": "integer", "minimum": 1 },
        "rollbackOnVerifyFail": { "type": "boolean", "default": false }
      }
    },
    "mode": {
      "type": "string",
      "enum": ["auto", "feature", "refactor", "medium", "microservice"],
      "default": "auto"
    },
    "clarificationAnswers": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "gateProfile": { "type": "string", "minLength": 1 },
    "retrieval": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "providerPriority": {
          "type": "array",
          "items": { "type": "string", "enum": ["qmd", "lexical", "semantic", "hybrid"] },
          "minItems": 1,
          "maxItems": 4
        },
        "topK": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "qmd": { "type": "integer", "minimum": 1, "maximum": 200 },
            "lexical": { "type": "integer", "minimum": 1, "maximum": 200 },
            "semantic": { "type": "integer", "minimum": 1, "maximum": 200 },
            "hybrid": { "type": "integer", "minimum": 1, "maximum": 200 },
            "final": { "type": "integer", "minimum": 1, "maximum": 200 }
          }
        },
        "timeoutMs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "qmd": { "type": "integer", "minimum": 100, "maximum": 20000 },
            "semantic": { "type": "integer", "minimum": 100, "maximum": 20000 },
            "provider": { "type": "integer", "minimum": 100, "maximum": 20000 }
          }
        },
        "stageTokenCaps": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "PLAN": { "type": "integer", "minimum": 200, "maximum": 12000 },
            "IMPLEMENT": { "type": "integer", "minimum": 200, "maximum": 12000 },
            "VERIFY": { "type": "integer", "minimum": 200, "maximum": 12000 }
          }
        },
        "embedding": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "endpoint": { "type": "string", "format": "uri" },
            "healthPath": { "type": "string", "minLength": 1 },
            "embedPath": { "type": "string", "minLength": 1 },
            "model": { "type": "string", "minLength": 1 },
            "timeoutMs": { "type": "integer", "minimum": 100, "maximum": 20000 },
            "maxBatchSize": { "type": "integer", "minimum": 1, "maximum": 512 },
            "cachePath": { "type": "string", "minLength": 1 }
          }
        },
        "lifecycle": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "chunkVersion": { "type": "string", "minLength": 1 },
            "retrievalVersion": { "type": "string", "minLength": 1 },
            "autoReindexOnStale": { "type": "boolean" }
          }
        },
        "qmd": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "command": { "type": "string", "minLength": 1 },
            "collectionName": { "type": "string", "minLength": 1 },
            "indexName": { "type": "string", "minLength": 1 },
            "mask": { "type": "string", "minLength": 1 },
            "queryMode": {
              "type": "string",
              "enum": ["query_then_search", "search_only", "query_only"]
            },
            "configDir": { "type": "string", "minLength": 1 },
            "cacheHome": { "type": "string", "minLength": 1 },
            "indexPath": { "type": "string", "minLength": 1 },
            "syncIntervalMs": { "type": "integer", "minimum": 1000, "maximum": 3600000 },
            "forceFailure": { "type": "boolean" }
          }
        }
      }
    },
    "dryRun": { "type": "boolean", "default": false }
  }
}
