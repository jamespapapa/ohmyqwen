{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnalyzeInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["taskId", "objective"],
  "properties": {
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "files": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "symbols": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "errorLogs": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "diffSummary": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "contextTier": {
      "type": "string",
      "enum": ["small", "mid", "big"],
      "default": "small"
    },
    "contextTokenBudget": {
      "type": "integer",
      "minimum": 200,
      "maximum": 8000,
      "default": 1200
    },
    "retryPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxAttempts", "backoffMs", "sameFailureLimit"],
      "properties": {
        "maxAttempts": { "type": "integer", "minimum": 1 },
        "backoffMs": { "type": "integer", "minimum": 0 },
        "sameFailureLimit": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
